# HTTP server address. Default: :8080
GATEWAY_ADDRESS=:8080

# Optional bearer token required by the gateway. Leave empty to disable gateway authentication.
GATEWAY_API_KEY=

# Required to forward requests to OpenAI.
OPENAI_API_KEY=

# OpenAI-compatible upstream endpoint. Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Upstream request timeout using Go duration syntax. Default: 60s
OPENAI_TIMEOUT=60s

# Anthropic API key. Leave empty to disable Anthropic provider.
ANTHROPIC_API_KEY=

# Anthropic API endpoint. Default: https://api.anthropic.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Anthropic request timeout. Default: 60s
ANTHROPIC_TIMEOUT=60s

# Azure OpenAI API key. Leave empty to disable Azure provider.
AZURE_API_KEY=

# Azure OpenAI endpoint (e.g., https://your-resource.openai.azure.com)
AZURE_BASE_URL=

# Azure OpenAI deployment name (required if using Azure)
AZURE_DEPLOYMENT=

# Azure request timeout. Default: 60s
AZURE_TIMEOUT=60s

